# 这是云端 Docker 部署的环境变量模板。
# 实际运行时请复制为同目录下的 .env，并在服务器本地明文填写。
# 注意：deploy/docker/.env 被 .gitignore 排除了，不会提交进 git。

# MySQL root 密码，仅容器内部初始化和维护使用。
MYSQL_ROOT_PASSWORD=ChangeThisRootPassword

# 应用连接 MySQL 使用的业务账号密码。
MYSQL_APP_PASSWORD=ChangeThisAppPassword

# 上传文件对外访问地址，云端部署时写成公网地址。
PUBLIC_UPLOAD_BASE_URL=http://8.136.24.4/uploads

# 当前视觉识别走方舟 OpenAI 兼容接口，只需要 API Key。
VISION_PROVIDER=ark
VISION_API_KEY=
VISION_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VISION_MODEL=doubao-seed-2-0-mini-260428
